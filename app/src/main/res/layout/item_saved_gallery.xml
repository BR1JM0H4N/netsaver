<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="6dp"
    app:cardBackgroundColor="?attr/colorSurfaceContainerHigh"
    app:cardCornerRadius="18dp"
    app:cardElevation="0dp"
    app:strokeColor="?attr/colorOutline"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="104dp"
            android:background="@drawable/bg_gallery_preview">

            <ImageView
                android:id="@+id/galleryPreview"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@drawable/ic_video"
                android:padding="28dp" />

            <TextView
                android:id="@+id/galleryKind"
                android:layout_width="wrap_content"
                android:layout_height="24dp"
                android:layout_gravity="bottom|start"
                android:layout_margin="8dp"
                android:gravity="center"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:textColor="?attr/colorOnPrimaryContainer"
                android:textSize="11sp"
                android:fontFamily="sans-serif-medium"
                android:background="@drawable/bg_save_chip" />
        </FrameLayout>

        <TextView
            android:id="@+id/galleryFileName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:layout_marginTop="10dp"
            android:layout_marginEnd="10dp"
            android:ellipsize="middle"
            android:maxLines="1"
            android:textColor="?attr/colorOnSurface"
            android:textSize="13sp"
            android:fontFamily="sans-serif-medium" />

        <TextView
            android:id="@+id/galleryFileMeta"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:layout_marginTop="2dp"
            android:layout_marginEnd="10dp"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:textSize="11sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:layout_marginTop="4dp"
            android:gravity="end|center_vertical"
            android:orientation="horizontal"
            android:paddingStart="6dp"
            android:paddingEnd="6dp">

            <ImageButton
                android:id="@+id/btnGalleryShare"
                android:layout_width="38dp"
                android:layout_height="38dp"
                android:src="@drawable/ic_share"
                android:background="@drawable/ripple_circle"
                android:contentDescription="Share saved file"
                android:padding="9dp" />

            <ImageButton
                android:id="@+id/btnGalleryDelete"
                android:layout_width="38dp"
                android:layout_height="38dp"
                android:layout_marginStart="2dp"
                android:src="@drawable/ic_delete"
                android:background="@drawable/ripple_circle"
                android:contentDescription="Delete saved file"
                android:padding="9dp" />
        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
